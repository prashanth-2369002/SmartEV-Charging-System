# Smart EV Charging System — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the real .env file.

# ─── MQTT Broker ──────────────────────────────────────────────────────────────
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — no extra setup needed)
DATABASE_URL=sqlite:///ev_charging.db

# PostgreSQL example (for production deployment):
# DATABASE_URL=postgresql://user:password@localhost:5432/ev_charging

# ─── Tariff ───────────────────────────────────────────────────────────────────
# ₹ per kWh — change to match your local electricity board rate
UNIT_RATE_RS=8.0

# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=replace-this-with-a-long-random-string
